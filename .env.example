# Copy this file to ".env.local" and fill in your Supabase values.
# Supabase dashboard → Project Settings → API.
#
# These two are SAFE to expose to the browser (the anon key is protected by Row-Level Security):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# The service-role key is a SECRET — only used by server-side migration scripts, NEVER shipped to
# the browser. Leave it out of the app entirely for now; add it only when we write data-migration
# scripts, and set it in Vercel as a (non-public) Environment Variable.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
