# Copy this file to ".env.local" and fill in your Supabase values.
# Supabase dashboard → Project Settings → API.
#
# These two are SAFE to expose to the browser (the anon key is protected by Row-Level Security):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# The service-role key is a SECRET — only used by server-side migration scripts, NEVER shipped to
# the browser. Leave it out of the app entirely for now; add it only when we write data-migration
# scripts, and set it in Vercel as a (non-public) Environment Variable.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# AI collaborator + agent hub. AGENT_HUB_SECRET can be separate, or leave it unset
# and the route will accept COLLABORATOR_AUDIT_SECRET.
# OPENAI_API_KEY=sk-...
# COLLABORATOR_AUDIT_SECRET=change-me
# AGENT_HUB_SECRET=change-me-too
# OPENAI_COLLABORATOR_MODEL=gpt-5

# Claude role keys. The agent hub uses Accounting for money, GM for dispatch,
# and Owner for price/margin. Missing role keys fall back to ANTHROPIC_KEY_OWNER
# and then ANTHROPIC_API_KEY.
# ANTHROPIC_KEY_OWNER=sk-ant-...
# ANTHROPIC_KEY_GM=sk-ant-...
# ANTHROPIC_KEY_ACCOUNTING=sk-ant-...
# ANTHROPIC_KEY_OFFICE=sk-ant-...
# ANTHROPIC_KEY_TECH=sk-ant-...
# ANTHROPIC_KEY_HELPER=sk-ant-...
# ANTHROPIC_AGENT_MODEL=claude-opus-4-8
